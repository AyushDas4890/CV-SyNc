PORT=4000

# ─── GitHub OAuth ────────────────────────────────────────────────
# Register at: github.com/settings/developers → OAuth Apps
# Callback: http://localhost:4000/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback
GITHUB_OAUTH_SCOPE=public_repo

# ─── Google OAuth ────────────────────────────────────────────────
# Register at: console.cloud.google.com → APIs & Services → Credentials
# Scopes needed: openid, email, profile
# Callback: http://localhost:4000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ─── Frontend ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Session ─────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string
REDIS_URL=redis://localhost:6379
