olor": "#ffe3e3", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": {"type": 3}, "seed": 1766964376, "version": 1, "versionNonce": 504459974, "isDeleted": false, "boundElements": null, "updated": 1784470813773, "link": null, "locked": false}, {"id": "zGBJHRRSKcSsGH07QqzsC", "type": "text", "x": 1658.0, "y": 435, "width": 84.0, "height": 25.0, "angle": 0, "strokeColor": "#e03131", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 1284432744, "version": 1, "versionNonce": 6438501, "isDeleted": false, "boundElements": null, "updated": 1784470813773, "link": null, "locked": false, "text": "GOTCHAS", "fontSize": 20, "fontFamily": 1, "textAlign": "center", "verticalAlign": "top", "containerId": null, "originalText": "GOTCHAS", "lineHeight": 1.25, "baseline": 20}, {"id": "2uOExO6tLCj9NBGym4kF5", "type": "text", "x": 1465, "y": 475, "width": 374.4, "height": 180.0, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 1477679228, "version": 1, "versionNonce": 73247525, "isDeleted": false, "boundElements": null, "updated": 1784470813773, "link": null, "locked": false, "text": "- autoescape=True: READMEs have & < >\n  raw they corrupt docx XML\n- COM wants ABSOLUTE paths\n- close LibreOffice windows or headless\n  hangs (timeout surfaces it)\n- missing fonts -> LO substitutes,\n  PDF looks wrong: install CV fonts\n- diff compares TEXT snapshots,\n  not docx bytes", "fontSize": 16, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "- autoescape=True: READMEs have & < >\n  raw they corrupt docx XML\n- COM wants ABSOLUTE paths\n- close LibreOffice windows or headless\n  hangs (timeout surfaces it)\n- missing fonts -> LO substitutes,\n  PDF looks wrong: install CV fonts\n- diff compares TEXT snapshots,\n  not docx bytes", "lineHeight": 1.25, "baseline": 16}, {"id": "iqEH3IPAWZsgqw3qNN7hV", "type": "rectangle", "x": 125.0, "y": 975.0, "width": 1150, "height": 90, "angle": 0, "strokeColor": "#495057", "backgroundColor": "#f1f3f5", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": {"type": 3}, "seed": 1444874540, "version": 1, "versionNonce": 412085364, "isDeleted": false, "boundElements": null, "updated": 1784470813773, "link": null, "locked": false}, {"id": "gN0Kd8xNSqzufdSz1dsl6", "type": "text", "x": 179.80000000000007, "y": 990, "width": 1040.3999999999999, "height": 21.25, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 1746402094, "version": 1, "versionNonce": 447443430, "isDeleted": false, "boundElements": null, "updated": 1784470813773, "link": null, "locked": false, "text": "BUILD ORDER:  0 template (riskiest - proves feasibility)  ->  1 fill  ->  3 convert  ->  2 review glue", "fontSize": 17, "fontFamily": 1, "textAlign": "center", "verticalAlign": "top", "containerId": null, "originalText": "BUILD ORDER:  0 template (riskiest - proves feasibility)  ->  1 fill  ->  3 convert  ->  2 review glue", "lineHeight": 1.25, "baseline": 17}, {"id": "563fKAGilBnCbfSAFTwdW", "type": "rectangle", "x": 940.0, "y": -60.0, "width": 440, "height": 240, "angle": 0, "strokeColor": "#1971c2", "backgroundColor": "#e7f5ff", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": {"type": 3}, "seed": 1585296689, "version": 1, "versionNonce": 738436372, "isDe