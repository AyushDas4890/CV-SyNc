PORT=4000

# GitHub OAuth App (github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback
# scope: public_repo per locked decision (07-decisions.md) — only public repos, no private access
GITHUB_OAUTH_SCOPE=public_repo

# where the frontend lives, for post-oauth redirect
FRONTEND_URL=http://localhost:5173

# session store
REDIS_URL=redis://localhost:6379
SESSION_SECRET=change-me
