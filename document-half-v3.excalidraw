"lineHeight": 1.25, "baseline": 14}, {"id": "bYQ8X6H9Uv8xleCm56ngG", "type": "arrow", "x": 880, "y": 40, "width": 60, "height": 10, "angle": 0, "strokeColor": "#1971c2", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "dashed", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": {"type": 2}, "seed": 728769813, "version": 1, "versionNonce": 1024944833, "isDeleted": false, "boundElements": null, "updated": 1784471156033, "link": null, "locked": false, "points": [[0, 0], [60, 10]], "lastCommittedPoint": null, "startBinding": null, "endBinding": null, "startArrowhead": null, "endArrowhead": "triangle"}, {"id": "pA3Bv3Y3QzQZNoszVIIZg", "type": "rectangle", "x": -170.0, "y": 345.0, "width": 460, "height": 270, "angle": 0, "strokeColor": "#f08c00", "backgroundColor": "#fff9db", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": {"type": 3}, "seed": 597912207, "version": 1, "versionNonce": 1428086514, "isDeleted": false, "boundElements": null, "updated": 1784471156033, "link": null, "locked": false}, {"id": "7TAkOuQh27X9qub7UyXbO", "type": "text", "x": -21.599999999999994, "y": 359.0, "width": 163.2, "height": 21.25, "angle": 0, "strokeColor": "#f08c00", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 1814839452, "version": 1, "versionNonce": 351327149, "isDeleted": false, "boundElements": null, "updated": 1784471156033, "link": null, "locked": false, "text": "inside review.py", "fontSize": 17, "fontFamily": 1, "textAlign": "center", "verticalAlign": "top", "containerId": null, "originalText": "inside review.py", "lineHeight": 1.25, "baseline": 17}, {"id": "ArL9SlHq9od3xbCzQzXq5", "type": "text", "x": -152.0, "y": 393.0, "width": 361.2, "height": 157.5, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 689112004, "version": 1, "versionNonce": 1664515525, "isDeleted": false, "boundElements": null, "updated": 1784471156033, "link": null, "locked": false, "text": "1. old = output/approved_snapshot.txt\n   (last y-approved text; empty on 1st run)\n2. new = text of cv_filled.docx\n   (python-docx: iterate paragraphs)\n3. difflib.unified_diff(old, new,\n   'current CV', 'proposed CV')\n4. print diff, input('Apply? [y/N]')\n5. y -> return True + overwrite snapshot\n   anything else -> sys.exit(0), untouched", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "1. old = output/approved_snapshot.txt\n   (last y-approved text; empty on 1st run)\n2. new = text of cv_filled.docx\n   (python-docx: iterate paragraphs)\n3. difflib.unified_diff(old, new,\n   'current CV', 'proposed CV')\n4. print diff, input('Apply? [y/N]')\n5. y -> return True + overwrite snapshot\n   anything else -> sys.exit(0), untouched", "lineHeight": 1.25, "baseline": 14}, {"id": "c2PU2HQx39jxM9rVacWgV", "type": "arrow", "x": 290, "y": 410, "width": 180, "height": 10, "angle": 0, "strokeColor": "#f08c00", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "dashed", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": {"type": 2}, "seed": 2016419656, "version": 1, "versionNonce": 183307601, "isDeleted": false, "boundElements": null, "updated": 1784471156033, "link": null, "locked": false, "points": [[0, 0], [180, 10]], "lastCommittedPoint": null, "startBinding": null, "endBinding": null, "startArrowhead": null, "endArrowhead": "triangle"}, {"id": "zemJMWlFLw9MRLchU9iQ5", "type": "rectangle", "x": 950.0, "y": 575.0, "width": 460, "height": 250, "angle": 0, "strokeColor": "#1971c2", "ba